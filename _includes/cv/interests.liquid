{% comment %}
  Unified interests entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      {% if entry.icon %}
        <i class="{{ entry.icon }}"></i>
      {% endif %}
      {{ entry.name }}
      {% if entry.keywords %}
        {% assign keywords = entry.keywords | split: ';' %}
        {% for keyword in keywords %}
          {% assign keyword = keyword | strip %}
          {% if forloop.last %}
            {{ keyword }}
          {% else %}
            {{ keyword }},
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.15rem 0;
  }
</style>
